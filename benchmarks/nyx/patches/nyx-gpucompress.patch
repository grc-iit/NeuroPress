+
 void mt_write(std::ofstream& output);
 
 using namespace amrex;
@@ -111,6 +115,162 @@ Nyx::writePlotFile (const std::string& dir,
                     VisMF::How         how)
 {
 
+#ifdef AMREX_USE_GPUCOMPRESS
+    if(use_gpucompress && parent->finestLevel() == 0)
+    {
+#ifndef NO_HYDRO
+    Real cur_time = state[State_Type].curTime();
+#else
+    Real cur_time = state[PhiGrav_Type].curTime();
+#endif
+
+    std::string dir_final = dir;
+    if(!amrex::AsyncOut::UseAsyncOut())
+    {
+        auto start_position_to_erase = dir_final.find(".temp");
+        if (start_position_to_erase != std::string::npos)
+            dir_final.erase(start_position_to_erase,5);
+    }
+
+    /* Assemble plotMF from state + derived variables */
+    std::vector<std::pair<int,int> > plot_var_map;
+    for (int typ = 0; typ < desc_lst.size(); typ++)
+        for (int comp = 0; comp < desc_lst[typ].nComp(); comp++)
+            if (parent->isStatePlotVar(desc_lst[typ].name(comp))
+                && desc_lst[typ].getType() == IndexType::TheCellType())
+                plot_var_map.push_back(std::pair<int,int>(typ, comp));
+
+    int num_derive = 0;
+    std::list<std::string> derive_names;
+    for (std::list<DeriveRec>::const_iterator it = derive_lst.dlist().begin();
+         it != derive_lst.dlist().end(); ++it)
+        if (parent->isDerivePlotVar(it->name())) {
+            derive_names.push_back(it->name());
+            num_derive++;
+        }
+
+    int n_data_items = plot_var_map.size() + num_derive;
+    int cnt = 0;
+    const int nGrow = 0;
+    MultiFab plotMF(grids, dmap, n_data_items, nGrow);
+    Vector<std::string> varnames;
+
+    for (int i = 0; i < (int)plot_var_map.size(); i++) {
+        int typ = plot_var_map[i].first;
+        int comp = plot_var_map[i].second;
+        varnames.push_back(desc_lst[typ].name(comp));
+        MultiFab::Copy(plotMF, state[typ].newData(), comp, cnt, 1, nGrow);
+        cnt++;
+    }
+    for (auto it = derive_names.begin(); it != derive_names.end(); ++it) {
+        varnames.push_back(*it);
+        const auto& derive_dat = derive(*it, cur_time, nGrow);
+        MultiFab::Copy(plotMF, *derive_dat, 0, cnt, 1, nGrow);
+        cnt++;
+    }
+
+    /* Initialize GPUCompress + HDF5 VOL connector (once) */
+    static hid_t vol_fapl = H5I_INVALID_HID;
+    if (vol_fapl < 0) {
+        std::string weights_path;
+        ParmParse pp_gc("nyx");
+        pp_gc.query("gpucompress_weights", weights_path);
+        const char* wp = weights_path.empty() ? NULL : weights_path.c_str();
+        vol_fapl = gpucompress_nyx_bridge::init(wp);
+
+        /* Policy: speed (w0=1,w1=0,w2=0), balanced (w0=1,w1=1,w2=0.5), ratio (w0=0,w1=0,w2=1) */
+        std::string policy = "ratio";
+        pp_gc.query("gpucompress_policy", policy);
+        if (policy == "speed")
+            gpucompress_set_ranking_weights(1.0f, 0.0f, 0.0f);
+        else if (policy == "balanced")
+            gpucompress_set_ranking_weights(1.0f, 1.0f, 0.5f);
+        else /* ratio */
+            gpucompress_set_ranking_weights(0.0f, 0.0f, 1.0f);
+
+        /* Enable online SGD learning + exploration for NN-RL+exp phase */
+        gpucompress_enable_online_learning();
+        {
+            float sgd_lr = 0.2f, sgd_mape = 0.10f, explore_thresh = 0.20f;
+            int explore_k = 4;
+            ParmParse pp_rl("nyx");
+            pp_rl.query("sgd_lr", sgd_lr);
+            pp_rl.query("sgd_mape", sgd_mape);
+            pp_rl.query("explore_thresh", explore_thresh);
+            pp_rl.query("explore_k", explore_k);
+            gpucompress_set_reinforcement(1, sgd_lr, sgd_mape, 0.0f);
+            gpucompress_set_exploration(1);
+            gpucompress_set_exploration_k(explore_k);
+            gpucompress_set_exploration_threshold(explore_thresh);
+        }
+
+        if (ParallelDescriptor::IOProcessor())
+            amrex::Print() << "GPUCompress VOL initialized (" << policy << " policy, online learning enabled)\n";
+    }
+
+    /* Read algorithm and verify flag from input */
+    std::string algo_str = "auto";
+    int gpucompress_verify = 0;
+    {
+        ParmParse pp_algo("nyx");
+        pp_algo.query("gpucompress_algorithm", algo_str);
+        pp_algo.query("gpucompress_verify", gpucompress_verify);
+    }
+    gpucompress_algorithm_t algo = gpucompress_algorithm_from_string(algo_str.c_str());
+
+    /* Per-chunk diagnostic logger for cross-workload regret benchmarks */
+    static gpucompress_nyx_bridge::DiagLogger diag_logger;
+    static int nyx_write_count = 0;
+    if (!diag_logger.enabled) {
+        const char* log_dir = getenv("NYX_LOG_DIR");
+        if (log_dir && log_dir[0]) {
+            /* Estimate total writes from max_step / plot_int */
+            int ms = 100;  /* fallback estimate */
+            int pi = 1;
+            { ParmParse pp_ms("amr");
+              pp_ms.query("max_step", ms);
+              pp_ms.query("plot_int", pi);
+              if (pi <= 0) pi = 1; }
+            int est_writes = (pi > 0) ? (ms / pi + 1) : 10;
+
+            /* Read policy weights */
+            float lw0 = 1, lw1 = 1, lw2 = 1;
+            std::string lpol = "ratio";
+            { ParmParse pp("nyx"); pp.query("gpucompress_policy", lpol); }
+            if (lpol == "speed")    { lw0=1; lw1=0; lw2=0; }
+            else if (lpol == "balanced") { lw0=1; lw1=1; lw2=0.5; }
+            else { lw0=0; lw1=0; lw2=1; }
+
+            if (ParallelDescriptor::IOProcessor()) {
+                amrex::UtilCreateDirectory(log_dir, 0755);
+                diag_logger.open(log_dir, "nyx", est_writes,
+                                 lw0, lw1, lw2, 0.0, 4*1024*1024);
+                amrex::Print() << "[GPUCompress] Chunk CSV logging to " << log_dir << "\n";
+            }
+        }
+    }
+
+    /* Write compressed HDF5 via VOL — same pattern as VPIC deck */
+    std::string gpuc_dir = dir_final + "_gpuc";
+    Real t0 = ParallelDescriptor::second();
+    long orig_bytes = gpucompress_nyx_bridge::write_multifab_compressed(
+        gpuc_dir, plotMF, varnames, vol_fapl,
+        4 * 1024 * 1024 /* 4 MiB chunks */,
+        algo, 0.0 /* lossless */,
+        gpucompress_verify != 0 /* verify */,
+        diag_logger.enabled ? &diag_logger : nullptr,
+        "nn-rl+exp50", nyx_write_count);
+    nyx_write_count++;
+    Real elapsed_ms = (ParallelDescriptor::second() - t0) * 1000.0;
+
+    if (ParallelDescriptor::IOProcessor())
+        amrex::Print() << "[GPUCompress] plotfile " << gpuc_dir
+                       << " algo=" << gpucompress_algorithm_name(algo)
+                       << ": " << orig_bytes / (1024*1024) << " MB in "
+                       << elapsed_ms << " ms\n";
+    }
+#endif
+
 #ifdef AMREX_USE_HDF5
     if(write_hdf5==1 && parent->finestLevel() == 0)
     {
@@ -245,10 +405,6 @@ Nyx::writePlotFile (const std::string& dir,
     WriteSingleLevelPlotfileHDF5(dir_final,
                           plotMF, varnames,
                           Geom(), cur_time, nStep());
-//                          const std::string &versionName,
-//                          const std::string &levelPrefix,
-//                          const std::string &mfPrefix,
-//                          const Vector<std::string>& extra_dirs)
     }
     else
 #endif
